{
  "manifest_version": 3,
  "name": "Chrome Vertical Tabs",
  "version": "1.1.2",
  "description": "Vertical tab organizer for Chrome with pinned and archived groups",
  
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Vertical Tabs",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
